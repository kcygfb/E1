{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "card-data.schema.json",
  "title": "Killkiss card category data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "category",
    "categoryName",
    "cards"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "category": {
      "enum": [
        "guns",
        "axes",
        "blades",
        "flexible_weapons",
        "hidden_weapons",
        "defense",
        "magic"
      ]
    },
    "categoryName": {
      "type": "string",
      "minLength": 1
    },
    "cards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/card"
      }
    }
  },
  "$defs": {
    "valuePair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base",
        "upgraded"
      ],
      "properties": {
        "base": {
          "type": "number"
        },
        "upgraded": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category",
        "cost",
        "special",
        "effects",
        "source",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "zhCN",
            "en"
          ],
          "properties": {
            "zhCN": {
              "type": "string",
              "minLength": 1
            },
            "en": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "category": {
          "enum": [
            "guns",
            "axes",
            "blades",
            "flexible_weapons",
            "hidden_weapons",
            "defense",
            "magic"
          ]
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "resource",
            "amount"
          ],
          "properties": {
            "resource": {
              "enum": [
                "action_point",
                "mana"
              ]
            },
            "amount": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "special": {
          "type": "boolean"
        },
        "effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "workbook",
            "sheet",
            "row",
            "rawLabel"
          ],
          "properties": {
            "workbook": {
              "type": "string"
            },
            "sheet": {
              "type": "string"
            },
            "row": {
              "type": "integer",
              "minimum": 1
            },
            "rawLabel": {
              "type": "string"
            }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "damage",
            "toughness_damage",
            "stun",
            "bleed",
            "poison",
            "vulnerability",
            "nullify_attacks",
            "damage_reduction",
            "skip_enemy_turns",
            "draw_cards",
            "immunity",
            "summon_companion",
            "life_steal_max_health",
            "gain_resource",
            "play_cards_from_discard"
          ]
        },
        "damageType": {
          "enum": [
            "normal",
            "true"
          ]
        },
        "amount": {
          "$ref": "#/$defs/valuePair"
        },
        "hits": {
          "$ref": "#/$defs/valuePair"
        },
        "minimumDamagePerHit": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "enum": [
            "points",
            "percent"
          ]
        },
        "durationTurns": {
          "$ref": "#/$defs/valuePair"
        },
        "damagePerTurn": {
          "type": "number",
          "minimum": 0
        },
        "stackable": {
          "type": "boolean"
        },
        "multiplier": {
          "type": "number"
        },
        "triggerCount": {
          "$ref": "#/$defs/valuePair"
        },
        "companionId": {
          "type": "string"
        },
        "normalTargetPercent": {
          "type": "number"
        },
        "bossPercent": {
          "type": "number"
        },
        "resource": {
          "enum": [
            "action_point",
            "mana"
          ]
        },
        "timing": {
          "enum": [
            "current_turn"
          ]
        },
        "selection": {
          "enum": [
            "player_choice"
          ]
        }
      }
    }
  }
}
